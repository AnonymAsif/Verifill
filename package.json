{
  "name": "verifill",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"vite\" \"node server/index.mjs\"",
    "build": "tsc && vite build",
    "preview": "concurrently -n web,api -c blue,green \"vite preview\" \"node server/index.mjs\"",
    "start": "NODE_ENV=production node server/index.mjs",
    "pdf-server": "node server/index.mjs"
  },
  "dependencies": {
    "express": "^4.21.2",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
